platform :ios, '15.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run flutter pub get first."
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end

  # CocoaPods can generate broken relative paths for Flutter's integration_test
  # pod after this workspace is moved between folders. Archive builds then fail
  # because Xcode resolves the headers under `/develop/flutter/...` instead of
  # the local Flutter SDK. Force these file references back to absolute SDK
  # paths during pod install.
  integration_test_sources = {
    'FLTIntegrationTestRunner.h' => 'integration_test/Sources/integration_test/include/FLTIntegrationTestRunner.h',
    'IntegrationTestIosTest.h' => 'integration_test/Sources/integration_test/include/IntegrationTestIosTest.h',
    'IntegrationTestPlugin.h' => 'integration_test/Sources/integration_test/include/IntegrationTestPlugin.h',
    'FLTIntegrationTestRunner.m' => 'integration_test/Sources/integration_test/FLTIntegrationTestRunner.m',
    'IntegrationTestIosTest.m' => 'integration_test/Sources/integration_test/IntegrationTestIosTest.m',
    'IntegrationTestPlugin.m' => 'integration_test/Sources/integration_test/IntegrationTestPlugin.m',
  }
  integration_test_root = File.realpath(File.join(flutter_root, 'packages', 'integration_test', 'ios'))
  installer.pods_project.files.each do |file_ref|
    next unless integration_test_sources.key?(file_ref.display_name)

    file_ref.source_tree = '<absolute>'
    file_ref.path = File.join(integration_test_root, integration_test_sources[file_ref.display_name])
  end
end
